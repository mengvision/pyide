# PyIDE Environment Configuration for LAN Deployment
# Copy this file to .env and modify according to your environment

# Database Configuration
POSTGRES_USER=pyide_user
POSTGRES_PASSWORD=pyide_secure_password_2024
POSTGRES_DB=pyide

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production

# API Configuration
# For LAN access, this should be the server's IP address
# Example: http://192.168.1.100:8000
SERVER_URL=http://localhost:8000

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Data Directory
PYIDE_DATA_DIR=/pyide-data

# Kernel Configuration
KERNEL_PORT_START=9000
KERNEL_PORT_END=9999

# Optional: AI Provider Configuration
# DEFAULT_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# DEFAULT_MODEL=gpt-4o
